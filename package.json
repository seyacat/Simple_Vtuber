{
  "name": "simple-vtuber",
  "version": "1.0.0",
  "description": "Vowel recognition system with TensorFlow.js training",
  "main": "app.js",
  "scripts": {
    "record": "node scripts/record.js",
    "record-batch": "node scripts/record_batch.js",
    "extract": "node scripts/extract_features.js",
    "train": "node scripts/train_model.js",
    "test": "node scripts/test_model.js",
    "train-all": "npm run extract && npm run train && npm run test",
    "start": "echo 'Open index.html in browser'"
  },
  "keywords": [
    "tensorflow",
    "vowel",
    "recognition",
    "speech",
    "machine-learning"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@tensorflow/tfjs": "^4.0.0",
    "@tensorflow/tfjs-node": "^4.0.0",
    "node-record-lpcm16": "^0.3.1",
    "wav-decoder": "^1.3.0",
    "wav-encoder": "^1.3.0",
    "meyda": "^5.2.0",
    "fs-extra": "^11.0.0",
    "minimist": "^1.2.8"
  },
  "devDependencies": {
    "@types/node": "^20.0.0"
  }
}