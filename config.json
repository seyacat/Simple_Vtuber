{
  "audio": {
    "sampleRate": 16000,
    "duration": 0.3,
    "channels": 1,
    "threshold": 0.02
  },

  "features": {
    "type": "melSpectrogram",
    "melBands": 64,
    "bufferSize": 512,
    "hopLength": 160,
    "windowFunction": "hann"
  },

  "dataset": {
    "normalize": true,
    "shuffle": true
  },

  "training": {
    "epochs": 120,
    "batchSize": 32,
    "validationSplit": 0.2,
    "learningRate": 0.0003,
    "earlyStoppingPatience": 20
  },

  "labels": [
    "A",
    "E",
    "I",
    "O",
    "U",
    "noise"
  ],

  "model": {
    "inputShape": [64,30,1],
    "outputClasses": 6
  }
}